# Files excluded from the WordPress.org SVN deploy (and the generated zip).
# Everything not listed here ships: the main plugin file, admin/, includes/,
# languages/, index.php, uninstall.php, README.txt, LICENSE.txt, and the
# committed block-editor build/ + src/ (src kept for the human-readable-code guideline).

# Dev tooling & CI
/.git
/.github
/bin
/tests
/blueprint
/node_modules
/vendor
/.playwright-cli
/playwright-report
/test-results

# Local assets repo (banners/icons live in the SVN /assets dir, not the package)
/.wordpress-org

# Dotfiles, build config, and dev docs not needed at runtime
.distignore
.gitignore
.DS_Store
.wp-env.json
CONTRIBUTING.md
composer.json
composer.lock
package.json
package-lock.json
phpunit.xml.dist
playwright.config.ts
